---
import { ArrowRight, Phone, CheckCircle } from '@lucide/astro';
import { SITE_CONFIG } from '../../config/site';

const benefits = [
  'Audit 100% gratuit',
  'Sans engagement',
  'Réponse sous 24h',
];
---

<section class="section-padding bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0 gradient-mesh opacity-50"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-500/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-white/5 border border-white/10 text-dark-300 text-sm font-medium rounded-full mb-6">
        Prêt à transformer votre habitat ?
      </span>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Commencez par un
        <span class="gradient-text">audit gratuit</span>
      </h2>

      <p class="text-lg text-dark-300 max-w-2xl mx-auto mb-8">
        Nos experts analysent votre logement et vos besoins pour vous proposer une solution personnalisée. Sans engagement.
      </p>

      <!-- Benefits -->
      <div class="flex flex-wrap items-center justify-center gap-6 mb-10">
        {benefits.map((benefit) => (
          <div class="flex items-center gap-2 text-dark-300">
            <CheckCircle class="w-5 h-5 text-accent-500" />
            <span>{benefit}</span>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/prendre-rdv" class="btn-primary group text-lg px-8 py-4">
          Demander mon audit gratuit
          <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
        <a href={SITE_CONFIG.phoneHref} class="btn-ghost text-dark-300 hover:text-white flex items-center gap-2">
          <Phone class="w-5 h-5" />
          {SITE_CONFIG.phone}
        </a>
      </div>
    </div>
  </div>
</section>
