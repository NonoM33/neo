---
import { Lightbulb, Wifi, Radio, Cpu, Link } from '@lucide/astro';

const partners = [
  { name: 'Philips Hue', icon: 'Lightbulb', color: 'text-yellow-500 bg-yellow-500/10' },
  { name: 'Shelly', icon: 'Wifi', color: 'text-blue-500 bg-blue-500/10' },
  { name: 'Zigbee', icon: 'Radio', color: 'text-green-500 bg-green-500/10' },
  { name: 'Matter', icon: 'Link', color: 'text-purple-500 bg-purple-500/10' },
  { name: 'Thread', icon: 'Cpu', color: 'text-cyan-500 bg-cyan-500/10' },
];
---

<section class="py-16 bg-dark-950 border-y border-dark-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <p class="text-sm font-medium text-dark-400 uppercase tracking-wider">
        Technologies & partenaires
      </p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
      {partners.map((partner, index) => (
        <div class={`animate-on-scroll animation-delay-${index % 4}00`}>
          <div class="group flex items-center gap-3 px-6 py-3 bg-dark-800/30 rounded-xl hover:bg-dark-700/50 transition-colors">
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${partner.color} group-hover:bg-primary-500 group-hover:text-white transition-colors`}>
              {partner.icon === 'Lightbulb' && <Lightbulb class="w-5 h-5" />}
              {partner.icon === 'Wifi' && <Wifi class="w-5 h-5" />}
              {partner.icon === 'Radio' && <Radio class="w-5 h-5" />}
              {partner.icon === 'Link' && <Link class="w-5 h-5" />}
              {partner.icon === 'Cpu' && <Cpu class="w-5 h-5" />}
            </div>
            <span class="text-dark-300 font-medium">{partner.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
