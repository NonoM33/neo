---
import { Star, Quote } from '@lucide/astro';

const testimonials = [
  {
    name: 'Marie L.',
    location: 'Paris 16ème',
    project: 'Appartement 120m²',
    quote: 'Installation impeccable et équipe très professionnelle. Ma maison est enfin connectée et tout fonctionne parfaitement ensemble !',
    rating: 5,
    initials: 'ML',
  },
  {
    name: 'Thomas B.',
    location: 'Neuilly-sur-Seine',
    project: 'Maison 200m²',
    quote: 'Le système de chauffage intelligent m\'a permis de réduire ma facture de 25%. L\'investissement est rentabilisé rapidement.',
    rating: 5,
    initials: 'TB',
  },
  {
    name: 'Sophie M.',
    location: 'Paris 7ème',
    project: 'Appartement 85m²',
    quote: 'Enfin une solution simple et fiable ! L\'application est intuitive et le support est toujours réactif.',
    rating: 5,
    initials: 'SM',
  },
];
---

<section class="section-padding bg-dark-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-600 text-sm font-medium rounded-full mb-4">
        Témoignages
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Ils nous font confiance
      </h2>
      <p class="text-lg text-dark-300 max-w-2xl mx-auto">
        Découvrez ce que nos clients disent de leur expérience avec Neo Domotique.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div class={`card-dark relative animate-on-scroll animation-delay-${index}00`}>
          <!-- Quote Icon -->
          <div class="absolute top-6 right-6 text-dark-600">
            <Quote class="w-8 h-8" />
          </div>

          <!-- Rating -->
          <div class="flex items-center gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <Star class="w-5 h-5 text-yellow-400 fill-yellow-400" />
            ))}
          </div>

          <!-- Quote -->
          <p class="text-dark-300 mb-6 leading-relaxed">
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-4 pt-4 border-t border-dark-700/50">
            <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-accent-500 rounded-full flex items-center justify-center text-white font-semibold">
              {testimonial.initials}
            </div>
            <div>
              <p class="font-semibold text-white">{testimonial.name}</p>
              <p class="text-sm text-dark-400">{testimonial.location} • {testimonial.project}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
