---
import { Lightbulb, Thermometer, Shield, BatteryCharging, ArrowRight } from '@lucide/astro';

const services = [
  {
    icon: 'Lightbulb',
    title: 'Éclairage intelligent',
    description: 'Automatisez votre éclairage selon vos habitudes. Ambiances personnalisées, économies d\'énergie et contrôle vocal.',
    color: 'primary',
  },
  {
    icon: 'Thermometer',
    title: 'Confort thermique',
    description: 'Chauffage et climatisation intelligents. Température idéale pièce par pièce, programmation et géolocalisation.',
    color: 'accent',
  },
  {
    icon: 'Shield',
    title: 'Sécurité connectée',
    description: 'Alarme, caméras, détecteurs. Surveillance en temps réel et alertes instantanées sur votre smartphone.',
    color: 'violet',
  },
  {
    icon: 'BatteryCharging',
    title: 'Économies d\'énergie',
    description: 'Réduisez votre facture énergétique jusqu\'à 30%. Suivi de consommation et optimisation automatique.',
    color: 'emerald',
  },
];
---

<section class="section-padding bg-dark-950 gradient-mesh">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-400 text-sm font-medium rounded-full mb-4">
        Nos services
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Une maison plus intelligente, plus confortable
      </h2>
      <p class="text-lg text-dark-400 max-w-2xl mx-auto">
        Des solutions domotiques adaptées à vos besoins, installées par des professionnels.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, index) => (
        <div class={`card-dark group animate-on-scroll animation-delay-${index}00`}>
          <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-6 ${
            service.color === 'primary' ? 'bg-primary-500/10 text-primary-400' :
            service.color === 'accent' ? 'bg-accent-500/10 text-accent-400' :
            service.color === 'violet' ? 'bg-violet-500/10 text-violet-400' :
            'bg-emerald-500/10 text-emerald-400'
          }`}>
            {service.icon === 'Lightbulb' && <Lightbulb class="w-7 h-7" />}
            {service.icon === 'Thermometer' && <Thermometer class="w-7 h-7" />}
            {service.icon === 'Shield' && <Shield class="w-7 h-7" />}
            {service.icon === 'BatteryCharging' && <BatteryCharging class="w-7 h-7" />}
          </div>
          <h3 class="text-lg font-semibold text-white mb-3 group-hover:text-primary-400 transition-colors">
            {service.title}
          </h3>
          <p class="text-dark-400 text-sm leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 animate-on-scroll">
      <a href="/services" class="btn-primary group">
        Découvrir tous nos services
        <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>
