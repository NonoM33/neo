---
import { ArrowRight } from '@lucide/astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background:linear-gradient(180deg, #0a0f1a 0%, #0d1528 40%, #0a0f1a 100%)">
  <!-- Subtle animated gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-primary-500/[0.07] rounded-full blur-[120px] animate-float"></div>
    <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] bg-accent-500/[0.05] rounded-full blur-[120px] animate-float" style="animation-delay:2s"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pt-16">
    <!-- Eyebrow -->
    <p class="text-primary-400/80 text-xs sm:text-sm font-medium tracking-[0.25em] uppercase mb-6 animate-fade-in">
      Domotique · Paris & Ile-de-France
    </p>

    <!-- Main headline -->
    <h1 class="text-[2.5rem] sm:text-6xl lg:text-[5.5rem] font-bold text-white leading-[1.05] tracking-tight mb-6 animate-slide-up">
      Votre maison<br/>
      <span class="gradient-text">intelligente</span>.
    </h1>

    <!-- Subtitle (Apple-style: short, precise) -->
    <p class="text-lg sm:text-xl lg:text-2xl text-white/50 max-w-2xl mx-auto leading-relaxed mb-10 animate-slide-up animation-delay-100 font-light">
      Installation cle en main. Eclairage, securite, chauffage.<br class="hidden sm:block"/>
      Tout fonctionne ensemble, simplement.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-slide-up animation-delay-200">
      <a href="/prendre-rdv" class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-medium text-white bg-primary-500 hover:bg-primary-400 rounded-full transition-all duration-300 shadow-lg shadow-primary-500/20 hover:shadow-primary-500/30">
        Audit gratuit
        <ArrowRight class="w-4 h-4" />
      </a>
      <a href="/comment-ca-marche" class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-medium text-white/60 hover:text-white transition-colors">
        Comment ca marche
        <ArrowRight class="w-4 h-4 opacity-50" />
      </a>
    </div>

    <!-- Trust (minimal) -->
    <div class="animate-slide-up animation-delay-300">
      <p class="text-white/25 text-sm">
        +150 installations · 4.9/5 satisfaction
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-5 h-8 border border-white/15 rounded-full flex justify-center pt-1.5">
      <div class="w-1 h-1.5 bg-white/30 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>
