---
import { Home, Menu, X, Phone } from '@lucide/astro';
import { SITE_CONFIG } from '../../config/site';

const navigation = [
  { name: 'Services', href: '/services' },
  { name: 'Tarifs', href: '/tarifs' },
  { name: 'Réalisations', href: '/realisations' },
  { name: 'Comment ça marche', href: '/comment-ca-marche' },
  { name: 'FAQ', href: '/faq' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div
          class="w-10 h-10 bg-gradient-to-br from-primary-500 to-accent-500 rounded-xl flex items-center justify-center shadow-lg shadow-primary-500/25 group-hover:shadow-primary-500/40 transition-shadow"
        >
          <Home class="w-5 h-5 text-white" />
        </div>
        <span class="text-xl font-bold text-white group-hover:text-primary-400 transition-colors"
          >Neo Domotique</span
        >
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {
          navigation.map((item) => {
            const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
            return (
              <a
                href={item.href}
                class={`text-sm font-medium transition-colors relative group ${isActive ? 'text-white' : 'text-dark-300 hover:text-white'}`}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.name}
                <span class={`absolute -bottom-1 left-0 h-0.5 bg-primary-500 transition-all duration-300 ${isActive ? 'w-full' : 'w-0 group-hover:w-full'}`} />
              </a>
            );
          })
        }
      </div>

      <!-- Phone + CTA Button -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={SITE_CONFIG.phoneHref}
          class="flex items-center gap-2 text-sm text-dark-300 hover:text-white transition-colors"
        >
          <Phone class="w-4 h-4" />
          {SITE_CONFIG.phone}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-primary-500 rounded-xl hover:bg-primary-600 transition-all duration-300 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:shadow-primary-500/30"
        >
          Prendre RDV
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="lg:hidden p-2 text-white hover:text-primary-400 transition-colors"
        aria-label="Menu"
      >
        <Menu class="w-6 h-6" id="menu-icon" />
        <X class="w-6 h-6 hidden" id="close-icon" />
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-dark-900/95 backdrop-blur-xl border-t border-dark-800"
  >
    <div class="max-w-7xl mx-auto px-4 py-6 space-y-4">
      {
        navigation.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class={`block py-3 text-lg font-medium transition-colors ${isActive ? 'text-white border-l-2 border-primary-500 pl-4' : 'text-dark-300 hover:text-white'}`}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.name}
            </a>
          );
        })
      }
      <div class="pt-4 border-t border-dark-800 space-y-3">
        <a
          href={SITE_CONFIG.phoneHref}
          class="flex items-center justify-center gap-2 py-3 text-base text-dark-300 hover:text-white transition-colors"
        >
          <Phone class="w-5 h-5" />
          {SITE_CONFIG.phone}
        </a>
        <a
          href="/contact"
          class="block w-full text-center py-3 text-base font-semibold text-white bg-primary-500 rounded-xl hover:bg-primary-600 transition-colors"
        >
          Prendre RDV - Audit gratuit
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  // Scroll behavior
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;

    if (currentScroll > 50) {
      header?.classList.add('bg-dark-950/90', 'backdrop-blur-xl', 'shadow-lg');
    } else {
      header?.classList.remove(
        'bg-dark-950/90',
        'backdrop-blur-xl',
        'shadow-lg'
      );
    }

    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
