---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config/site';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Prendre rendez-vous - Neo Domotique",
  "description": "Choisissez un creneau et prenez rendez-vous en ligne."
};
---

<BaseLayout
  title="Prendre RDV"
  description="Choisissez un creneau disponible et prenez rendez-vous en ligne pour votre audit gratuit."
  canonical="/prendre-rdv"
  schema={schema}
>
  <section class="min-h-screen bg-dark-950 pt-20 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Prendre <span class="gradient-text">rendez-vous</span></h1>
        <p class="text-dark-400">Choisissez un creneau et reservez votre audit gratuit.</p>
      </div>

      <!-- Main booking card -->
      <div id="booking" class="bg-dark-900/50 border border-dark-700/50 rounded-2xl overflow-hidden" data-api={SITE_CONFIG.apiBaseUrl}>

        <!-- Type selector (top bar) -->
        <div class="flex border-b border-dark-700/50 overflow-x-auto">
          <button data-type="visite_technique" class="rdv-type flex-1 flex items-center justify-center gap-2 px-4 py-3.5 text-sm font-medium text-white/60 hover:text-white border-b-2 border-transparent transition-all whitespace-nowrap">
            <span>🔧</span> Visite technique <span class="text-dark-500 text-xs">1h30</span>
          </button>
          <button data-type="audit" class="rdv-type flex-1 flex items-center justify-center gap-2 px-4 py-3.5 text-sm font-medium text-white/60 hover:text-white border-b-2 border-transparent transition-all whitespace-nowrap">
            <span>📋</span> Audit complet <span class="text-dark-500 text-xs">2h</span>
          </button>
          <button data-type="rdv_commercial" class="rdv-type flex-1 flex items-center justify-center gap-2 px-4 py-3.5 text-sm font-medium text-white/60 hover:text-white border-b-2 border-transparent transition-all whitespace-nowrap">
            <span>💼</span> RDV Commercial <span class="text-dark-500 text-xs">1h</span>
          </button>
        </div>

        <!-- Calendar + Slots side by side -->
        <div class="grid lg:grid-cols-[1fr,280px] min-h-[420px]">

          <!-- Left: Calendar -->
          <div class="p-6 border-b lg:border-b-0 lg:border-r border-dark-700/50">
            <div class="flex items-center justify-between mb-5">
              <button id="cal-prev" class="w-8 h-8 rounded-lg bg-dark-800 hover:bg-dark-700 text-white/60 hover:text-white flex items-center justify-center transition-colors">&larr;</button>
              <h3 id="cal-month" class="text-white font-semibold text-sm"></h3>
              <button id="cal-next" class="w-8 h-8 rounded-lg bg-dark-800 hover:bg-dark-700 text-white/60 hover:text-white flex items-center justify-center transition-colors">&rarr;</button>
            </div>
            <!-- Day headers -->
            <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:8px;">
              <div class="text-center text-xs text-dark-500 py-1">Lun</div>
              <div class="text-center text-xs text-dark-500 py-1">Mar</div>
              <div class="text-center text-xs text-dark-500 py-1">Mer</div>
              <div class="text-center text-xs text-dark-500 py-1">Jeu</div>
              <div class="text-center text-xs text-dark-500 py-1">Ven</div>
              <div class="text-center text-xs text-dark-500 py-1">Sam</div>
              <div class="text-center text-xs text-dark-500 py-1">Dim</div>
            </div>
            <!-- Calendar grid -->
            <div id="cal-grid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;"></div>
          </div>

          <!-- Right: Time slots -->
          <div class="p-5 overflow-y-auto max-h-[420px]">
            <div id="slots-header" class="text-sm text-dark-400 mb-4">Selectionnez un jour</div>
            <div id="slots-list" class="space-y-2"></div>
            <div id="slots-empty" class="hidden text-center py-8">
              <div class="text-dark-500 text-3xl mb-2">📅</div>
              <p class="text-dark-400 text-sm">Aucun creneau</p>
            </div>
            <div id="slots-loading" class="hidden text-center py-8">
              <div class="w-6 h-6 border-2 border-primary-500 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
              <p class="text-dark-400 text-sm">Chargement...</p>
            </div>
          </div>
        </div>

        <!-- Selected summary bar (appears when slot chosen) -->
        <div id="summary-bar" class="hidden border-t border-dark-700/50 bg-dark-800/50 px-6 py-4">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-4 text-sm">
              <span class="text-dark-400">📅 <span id="sum-date" class="text-white font-medium"></span></span>
              <span class="text-dark-400">🕐 <span id="sum-time" class="text-white font-medium"></span></span>
              <span class="text-dark-400">📝 <span id="sum-type" class="text-white font-medium"></span></span>
            </div>
            <button id="btn-confirm" class="px-6 py-2.5 bg-primary-500 hover:bg-primary-400 text-white text-sm font-medium rounded-xl transition-colors">
              Confirmer →
            </button>
          </div>
        </div>

        <!-- Confirmation form (slides in) -->
        <div id="form-panel" class="hidden border-t border-dark-700/50 bg-dark-900/80 p-6">
          <h3 class="text-lg font-semibold text-white mb-4">Vos coordonnees</h3>
          <form id="booking-form" class="grid sm:grid-cols-2 gap-4">
            <input type="text" name="firstName" placeholder="Prenom *" required class="rdv-input" />
            <input type="text" name="lastName" placeholder="Nom *" required class="rdv-input" />
            <input type="email" name="email" placeholder="Email *" required class="rdv-input" />
            <input type="tel" name="phone" placeholder="Telephone *" required class="rdv-input" />
            <input type="text" name="postalCode" placeholder="Code postal *" required pattern="[0-9]{5}" class="rdv-input" />
            <select name="housingType" class="rdv-input">
              <option value="">Type de logement</option>
              <option value="appartement">Appartement</option>
              <option value="maison">Maison</option>
              <option value="autre">Autre</option>
            </select>
            <textarea name="message" placeholder="Message (optionnel)" rows="3" class="rdv-input sm:col-span-2"></textarea>
            <!-- Honeypot -->
            <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
            <div class="sm:col-span-2 flex items-start gap-2">
              <input type="checkbox" name="consent" required id="consent" class="mt-1 accent-primary-500" />
              <label for="consent" class="text-xs text-dark-400">J'accepte que mes donnees soient traitees pour ma demande de rendez-vous.</label>
            </div>
            <div class="sm:col-span-2 flex gap-3">
              <button type="button" id="btn-back" class="px-6 py-2.5 text-sm text-dark-400 hover:text-white border border-dark-600 rounded-xl transition-colors">← Retour</button>
              <button type="submit" id="btn-submit" class="flex-1 px-6 py-2.5 bg-primary-500 hover:bg-primary-400 text-white text-sm font-medium rounded-xl transition-colors">Confirmer le rendez-vous</button>
            </div>
          </form>
        </div>

        <!-- Success -->
        <div id="success-panel" class="hidden p-10 text-center">
          <div class="text-5xl mb-4">✅</div>
          <h3 class="text-2xl font-bold text-white mb-2">Rendez-vous confirme !</h3>
          <p id="success-detail" class="text-dark-300 mb-6"></p>
          <a href="/" class="inline-flex items-center gap-2 px-6 py-3 text-sm text-white bg-primary-500 hover:bg-primary-400 rounded-xl transition-colors">Retour a l'accueil</a>
        </div>
      </div>

      <!-- Info -->
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-dark-500">
        <span>✓ 100% gratuit</span>
        <span>✓ Sans engagement</span>
        <span>✓ Reponse sous 24h</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .rdv-type.active {
    color: white;
    border-bottom-color: #3B82F6;
    background: rgba(59,130,246,0.05);
  }
  .rdv-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    background: rgba(30,30,45,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.75rem;
    color: white;
    font-size: 0.875rem;
  }
  .rdv-input::placeholder { color: rgba(255,255,255,0.3); }
  .rdv-input:focus { outline: none; border-color: #3B82F6; box-shadow: 0 0 0 2px rgba(59,130,246,0.2); }
  .cal-day {
    width: 100%;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.15s;
    cursor: default;
    color: rgba(255,255,255,0.3);
  }
  .cal-day.available {
    color: white;
    cursor: pointer;
    background: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.2);
  }
  .cal-day.available:hover { background: rgba(59,130,246,0.25); }
  .cal-day.selected { background: #3B82F6 !important; color: white; border-color: #3B82F6; font-weight: 600; }
  .cal-day.past { color: rgba(255,255,255,0.15); }
  .cal-day.empty { color: transparent; }
  .cal-day.today { box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2); }
  .slot-btn {
    width: 100%;
    padding: 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: white;
    background: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.2);
    transition: all 0.15s;
    cursor: pointer;
    text-align: center;
  }
  .slot-btn:hover { background: rgba(59,130,246,0.25); }
  .slot-btn.selected { background: #3B82F6; border-color: #3B82F6; }
</style>

<script is:inline>
(function() {
  var API = document.getElementById('booking')?.dataset.api || '';
  var state = { type: 'visite_technique', month: new Date().getMonth(), year: new Date().getFullYear(), selectedDate: null, selectedSlot: null, allSlots: [] };
  var typeLabels = { visite_technique: 'Visite technique', audit: 'Audit complet', rdv_commercial: 'RDV Commercial' };
  var typeDurations = { visite_technique: 90, audit: 120, rdv_commercial: 60 };
  var MONTHS = ['Janvier','Fevrier','Mars','Avril','Mai','Juin','Juillet','Aout','Septembre','Octobre','Novembre','Decembre'];
  var today = new Date(); today.setHours(0,0,0,0);

  // Elements
  var calGrid = document.getElementById('cal-grid');
  var calMonth = document.getElementById('cal-month');
  var slotsList = document.getElementById('slots-list');
  var slotsHeader = document.getElementById('slots-header');
  var slotsEmpty = document.getElementById('slots-empty');
  var slotsLoading = document.getElementById('slots-loading');
  var summaryBar = document.getElementById('summary-bar');
  var formPanel = document.getElementById('form-panel');
  var successPanel = document.getElementById('success-panel');

  // Type buttons
  document.querySelectorAll('.rdv-type').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.rdv-type').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      state.type = btn.dataset.type;
      state.selectedDate = null;
      state.selectedSlot = null;
      summaryBar.classList.add('hidden');
      formPanel.classList.add('hidden');
      fetchSlots();
    });
  });
  // Init first type
  document.querySelector('[data-type="visite_technique"]').classList.add('active');

  // Calendar nav
  document.getElementById('cal-prev').addEventListener('click', function() {
    state.month--;
    if (state.month < 0) { state.month = 11; state.year--; }
    renderCalendar();
  });
  document.getElementById('cal-next').addEventListener('click', function() {
    state.month++;
    if (state.month > 11) { state.month = 0; state.year++; }
    renderCalendar();
  });

  function renderCalendar() {
    calMonth.textContent = MONTHS[state.month] + ' ' + state.year;
    calGrid.innerHTML = '';

    var first = new Date(state.year, state.month, 1);
    var startDay = (first.getDay() + 6) % 7; // Monday = 0
    var daysInMonth = new Date(state.year, state.month + 1, 0).getDate();

    // Available dates from slots
    var availableDates = new Set();
    state.allSlots.forEach(function(s) { availableDates.add(s.date); });
    console.log('Rendering calendar:', MONTHS[state.month], state.year, '| Available dates:', availableDates.size, '| Days in month:', daysInMonth, '| Start day offset:', startDay);

    // Empty cells before first day
    for (var i = 0; i < startDay; i++) {
      var empty = document.createElement('div');
      empty.className = 'cal-day empty';
      calGrid.appendChild(empty);
    }

    for (var d = 1; d <= daysInMonth; d++) {
      var date = new Date(state.year, state.month, d);
      var dateStr = date.getFullYear() + '-' + String(date.getMonth()+1).padStart(2,'0') + '-' + String(date.getDate()).padStart(2,'0');
      var cell = document.createElement('div');
      cell.className = 'cal-day';
      cell.textContent = d;

      if (date < today) {
        cell.classList.add('past');
      } else if (date.getDay() === 0) {
        cell.classList.add('past');
      } else if (availableDates.has(dateStr)) {
        cell.classList.add('available');
        cell.dataset.date = dateStr;
        cell.addEventListener('click', function() {
          var dt = this.dataset.date;
          state.selectedDate = dt;
          state.selectedSlot = null;
          summaryBar.classList.add('hidden');
          formPanel.classList.add('hidden');
          document.querySelectorAll('.cal-day.selected').forEach(function(c) { c.classList.remove('selected'); });
          this.classList.add('selected');
          renderSlots();
        });
      } else {
        cell.classList.add('past');
      }

      var todayStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');
      if (dateStr === todayStr) cell.classList.add('today');
      if (state.selectedDate === dateStr) cell.classList.add('selected');

      calGrid.appendChild(cell);
    }
  }

  function renderSlots() {
    slotsList.innerHTML = '';
    slotsEmpty.classList.add('hidden');
    if (!state.selectedDate) { slotsHeader.textContent = 'Selectionnez un jour'; return; }

    var daySlots = state.allSlots.filter(function(s) { return s.date === state.selectedDate; });
    var d = new Date(state.selectedDate + 'T00:00:00');
    slotsHeader.textContent = d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });

    if (daySlots.length === 0) { slotsEmpty.classList.remove('hidden'); return; }

    // Group by morning/afternoon
    var morning = daySlots.filter(function(s) { return parseInt(s.startTime) < 12; });
    var afternoon = daySlots.filter(function(s) { return parseInt(s.startTime) >= 12; });

    function addGroup(label, slots) {
      if (slots.length === 0) return;
      var lbl = document.createElement('div');
      lbl.className = 'text-xs text-dark-500 uppercase tracking-wider mb-2 mt-3';
      lbl.textContent = label;
      slotsList.appendChild(lbl);

      var grid = document.createElement('div');
      grid.className = 'grid grid-cols-3 gap-2';
      slots.forEach(function(s) {
        var btn = document.createElement('button');
        btn.className = 'slot-btn';
        btn.textContent = s.startTime;
        btn.dataset.start = s.startTime;
        btn.dataset.end = s.endTime;
        if (state.selectedSlot && state.selectedSlot.startTime === s.startTime) btn.classList.add('selected');
        btn.addEventListener('click', function() {
          state.selectedSlot = { startTime: s.startTime, endTime: s.endTime };
          document.querySelectorAll('.slot-btn.selected').forEach(function(b) { b.classList.remove('selected'); });
          btn.classList.add('selected');
          showSummary();
        });
        grid.appendChild(btn);
      });
      slotsList.appendChild(grid);
    }

    addGroup('Matin', morning);
    addGroup('Apres-midi', afternoon);
  }

  function showSummary() {
    var d = new Date(state.selectedDate + 'T00:00:00');
    document.getElementById('sum-date').textContent = d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
    document.getElementById('sum-time').textContent = state.selectedSlot.startTime + ' - ' + state.selectedSlot.endTime;
    document.getElementById('sum-type').textContent = typeLabels[state.type];
    summaryBar.classList.remove('hidden');
    formPanel.classList.add('hidden');
  }

  // Confirm button -> show form
  document.getElementById('btn-confirm').addEventListener('click', function() {
    formPanel.classList.remove('hidden');
    formPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Back button
  document.getElementById('btn-back').addEventListener('click', function() {
    formPanel.classList.add('hidden');
  });

  // Submit
  document.getElementById('booking-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var btn = document.getElementById('btn-submit');
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    try {
      var body = {
        type: state.type,
        date: state.selectedDate,
        startTime: state.selectedSlot.startTime,
        endTime: state.selectedSlot.endTime,
        firstName: form.firstName.value,
        lastName: form.lastName.value,
        email: form.email.value,
        phone: form.phone.value,
        postalCode: form.postalCode.value,
        housingType: form.housingType.value || undefined,
        message: form.message.value || undefined,
        consent: true,
        website: form.website.value,
      };

      var res = await fetch(API + '/api/public/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      var data = await res.json();
      if (res.ok && data.success) {
        var d = new Date(state.selectedDate + 'T00:00:00');
        document.getElementById('success-detail').textContent =
          typeLabels[state.type] + ' le ' + d.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' }) +
          ' a ' + state.selectedSlot.startTime + (data.assignedTo ? ' avec ' + data.assignedTo : '');

        // Hide everything except success
        document.querySelectorAll('.rdv-type').forEach(function(b) { b.parentElement.style.display = 'none'; });
        calGrid.parentElement.parentElement.parentElement.style.display = 'none';
        summaryBar.style.display = 'none';
        formPanel.style.display = 'none';
        successPanel.classList.remove('hidden');
      } else {
        alert(data.error?.message || 'Erreur lors de la reservation');
        btn.disabled = false;
        btn.textContent = 'Confirmer le rendez-vous';
      }
    } catch (err) {
      alert('Erreur reseau');
      btn.disabled = false;
      btn.textContent = 'Confirmer le rendez-vous';
    }
  });

  // Fetch slots
  async function fetchSlots() {
    slotsLoading.classList.remove('hidden');
    slotsEmpty.classList.add('hidden');
    slotsList.innerHTML = '';
    slotsHeader.textContent = 'Chargement...';

    // Build date strings without timezone issues
    var now = new Date();
    var fromStr = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0');
    var to = new Date(now.getTime() + 14 * 24 * 60 * 60 * 1000);
    var toStr = to.getFullYear() + '-' + String(to.getMonth()+1).padStart(2,'0') + '-' + String(to.getDate()).padStart(2,'0');

    var url = API + '/api/public/booking/slots?type=' + state.type + '&fromDate=' + fromStr + '&toDate=' + toStr;
    console.log('Fetching slots:', url);

    try {
      var res = await fetch(url);
      var data = await res.json();
      console.log('Slots received:', data.slots?.length || 0);
      // Filter out slots less than 24h from now
      var minTime = Date.now() + 24 * 60 * 60 * 1000;
      state.allSlots = (data.slots || []).filter(function(s) {
        var slotTime = new Date(s.date + 'T' + s.startTime + ':00').getTime();
        return slotTime >= minTime;
      });
    } catch (e) {
      console.error('Fetch error:', e);
      state.allSlots = [];
    }
    slotsLoading.classList.add('hidden');
    slotsHeader.textContent = 'Selectionnez un jour';
    renderCalendar();
  }

  // Init
  fetchSlots();
})();
</script>
