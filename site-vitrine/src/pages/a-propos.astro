---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/sections/CTA.astro';
import { Heart, Shield, Zap, Users, Award, CheckCircle } from '@lucide/astro';

const values = [
  {
    icon: 'Heart',
    title: 'Passion',
    description: 'Nous sommes passionnés par la technologie et l\'amélioration du quotidien de nos clients.',
  },
  {
    icon: 'Shield',
    title: 'Fiabilité',
    description: 'Nous utilisons uniquement des équipements de qualité et des technologies éprouvées.',
  },
  {
    icon: 'Zap',
    title: 'Innovation',
    description: 'Nous restons à la pointe des dernières avancées en domotique et smart home.',
  },
  {
    icon: 'Users',
    title: 'Proximité',
    description: 'Un interlocuteur dédié et un accompagnement personnalisé pour chaque projet.',
  },
];

const team = [
  {
    name: 'Alexandre Martin',
    role: 'Fondateur & Expert domotique',
    description: 'Passionné de domotique depuis 10 ans, Alexandre a fondé Neo Domotique pour démocratiser la maison connectée.',
    initials: 'AM',
  },
  {
    name: 'Sophie Dubois',
    role: 'Responsable technique',
    description: 'Ingénieure de formation, Sophie supervise toutes les installations et garantit leur qualité.',
    initials: 'SD',
  },
  {
    name: 'Thomas Bernard',
    role: 'Technicien senior',
    description: 'Électricien certifié et expert Home Assistant, Thomas réalise les installations les plus complexes.',
    initials: 'TB',
  },
];

const commitments = [
  'Installation soignée et propre',
  'Formation complète incluse',
  'Support réactif après installation',
  'Garantie satisfaction client',
  'Devis gratuit et sans engagement',
  'Prix transparents sans surprise',
];
---

<BaseLayout
  title="À propos - Notre équipe et nos valeurs"
  description="Découvrez Neo Domotique : notre histoire, notre équipe et notre engagement pour rendre la maison connectée accessible à tous."
  canonical="/a-propos"
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark-950 gradient-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-400 text-sm font-medium rounded-full mb-6">
          À propos de nous
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Rendre la domotique <span class="gradient-text">accessible à tous</span>
        </h1>
        <p class="text-lg text-dark-300">
          Depuis 2020, nous transformons les habitats parisiens en maisons intelligentes. Notre mission : simplifier la technologie pour améliorer votre quotidien.
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-dark-900 mb-6">Notre histoire</h2>
          <div class="space-y-4 text-dark-600">
            <p>
              Neo Domotique est née d'un constat simple : la domotique reste trop complexe pour la majorité des particuliers. Entre les protocoles incompatibles, les configurations techniques et le manque de support, beaucoup abandonnent avant même de commencer.
            </p>
            <p>
              Nous avons créé Neo Domotique pour changer cela. Notre approche clé en main permet à chacun de profiter d'une maison connectée sans avoir à devenir un expert technique.
            </p>
            <p>
              Basés à Paris, nous intervenons dans toute l'Île-de-France. Notre équipe d'experts passionnés combine expertise technique et sens du service pour offrir une expérience sans stress.
            </p>
          </div>
        </div>

        <div class="animate-on-scroll animation-delay-200">
          <div class="bg-gradient-to-br from-primary-500 to-accent-500 rounded-2xl p-8 text-white">
            <h3 class="text-2xl font-bold mb-6">Pourquoi Home Assistant ?</h3>
            <p class="text-white/90 mb-6">
              Nous avons choisi Home Assistant comme plateforme centrale car c'est la solution la plus ouverte, évolutive et respectueuse de votre vie privée.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <CheckCircle class="w-5 h-5 flex-shrink-0 mt-0.5" />
                <span>Compatible avec +2000 marques et appareils</span>
              </li>
              <li class="flex items-start gap-3">
                <CheckCircle class="w-5 h-5 flex-shrink-0 mt-0.5" />
                <span>Fonctionne en local, pas de dépendance cloud</span>
              </li>
              <li class="flex items-start gap-3">
                <CheckCircle class="w-5 h-5 flex-shrink-0 mt-0.5" />
                <span>Open source et évolutif</span>
              </li>
              <li class="flex items-start gap-3">
                <CheckCircle class="w-5 h-5 flex-shrink-0 mt-0.5" />
                <span>Automatisations puissantes et personnalisables</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-padding bg-dark-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-dark-900 mb-4">Nos valeurs</h2>
        <p class="text-dark-600">Ce qui nous guide au quotidien</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value, index) => (
          <div class={`card text-center animate-on-scroll animation-delay-${index}00`}>
            <div class="w-14 h-14 mx-auto mb-4 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500">
              {value.icon === 'Heart' && <Heart class="w-7 h-7" />}
              {value.icon === 'Shield' && <Shield class="w-7 h-7" />}
              {value.icon === 'Zap' && <Zap class="w-7 h-7" />}
              {value.icon === 'Users' && <Users class="w-7 h-7" />}
            </div>
            <h3 class="text-lg font-semibold text-dark-900 mb-2">{value.title}</h3>
            <p class="text-dark-600 text-sm">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-dark-900 mb-4">Notre équipe</h2>
        <p class="text-dark-600">Des experts passionnés à votre service</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {team.map((member, index) => (
          <div class={`card text-center animate-on-scroll animation-delay-${index}00`}>
            <div class="w-20 h-20 mx-auto mb-4 bg-gradient-to-br from-primary-500 to-accent-500 rounded-full flex items-center justify-center text-white text-2xl font-bold">
              {member.initials}
            </div>
            <h3 class="text-lg font-semibold text-dark-900 mb-1">{member.name}</h3>
            <p class="text-primary-500 text-sm font-medium mb-3">{member.role}</p>
            <p class="text-dark-600 text-sm">{member.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commitments -->
  <section class="section-padding bg-dark-950 gradient-mesh">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-4">Nos engagements</h2>
        <p class="text-dark-300">Ce que nous vous garantissons</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        {commitments.map((commitment, index) => (
          <div class={`flex items-center gap-3 p-4 bg-dark-800/50 rounded-xl border border-dark-700/50 animate-on-scroll animation-delay-${index % 3}00`}>
            <Award class="w-6 h-6 text-accent-500 flex-shrink-0" />
            <span class="text-white">{commitment}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
