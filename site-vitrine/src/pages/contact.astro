---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { SITE_CONFIG } from '../config/site';
import { Mail, Phone, MapPin, Clock, CheckCircle, Send } from '@lucide/astro';

const housingTypes = [
  { value: 'appartement', label: 'Appartement' },
  { value: 'maison', label: 'Maison' },
  { value: 'autre', label: 'Autre' },
];

const needs = [
  { value: 'eclairage', label: 'Éclairage' },
  { value: 'volets', label: 'Volets' },
  { value: 'chauffage', label: 'Chauffage' },
  { value: 'securite', label: 'Sécurité' },
  { value: 'multimedia', label: 'Multimédia' },
  { value: 'autre', label: 'Autre' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact - Neo Domotique",
  "description": "Prenez rendez-vous pour un audit gratuit de votre logement."
};
---

<BaseLayout
  title="Contact & RDV - Audit gratuit"
  description="Prenez rendez-vous pour un audit gratuit de votre logement. Réponse sous 24h. Intervention Paris et Île-de-France."
  canonical="/contact"
  schema={schema}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark-950 gradient-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-400 text-sm font-medium rounded-full mb-6">
          Contact
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Demandez votre <span class="gradient-text">audit gratuit</span>
        </h1>
        <p class="text-lg text-dark-300">
          Remplissez le formulaire et nous vous recontactons sous 24h pour planifier votre audit à domicile.
        </p>
      </div>
    </div>
  </section>

  <Breadcrumbs items={[{ label: 'Contact' }]} />

  <!-- Contact Section -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-8">
          <div class="card">
            <h2 class="text-xl font-bold text-dark-900 mb-6">Coordonnées</h2>
            <ul class="space-y-6">
              <li>
                <a href={`mailto:${SITE_CONFIG.email}`} class="flex items-start gap-4 group">
                  <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500 group-hover:bg-primary-500 group-hover:text-white transition-colors">
                    <Mail class="w-5 h-5" />
                  </div>
                  <div>
                    <p class="text-sm text-dark-500 mb-1">Email</p>
                    <p class="font-medium text-dark-900 group-hover:text-primary-500 transition-colors">{SITE_CONFIG.email}</p>
                  </div>
                </a>
              </li>
              <li>
                <a href={SITE_CONFIG.phoneHref} class="flex items-start gap-4 group">
                  <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500 group-hover:bg-primary-500 group-hover:text-white transition-colors">
                    <Phone class="w-5 h-5" />
                  </div>
                  <div>
                    <p class="text-sm text-dark-500 mb-1">Téléphone</p>
                    <p class="font-medium text-dark-900 group-hover:text-primary-500 transition-colors">{SITE_CONFIG.phone}</p>
                  </div>
                </a>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500">
                  <MapPin class="w-5 h-5" />
                </div>
                <div>
                  <p class="text-sm text-dark-500 mb-1">Zone d'intervention</p>
                  <p class="font-medium text-dark-900">{SITE_CONFIG.address.areaServed}</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500">
                  <Clock class="w-5 h-5" />
                </div>
                <div>
                  <p class="text-sm text-dark-500 mb-1">Horaires</p>
                  <p class="font-medium text-dark-900">{SITE_CONFIG.openingHoursDisplay}</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="card bg-dark-950 text-white">
            <h3 class="font-semibold mb-4">Ce qu'inclut l'audit gratuit</h3>
            <ul class="space-y-3">
              {['Visite à domicile (1h)', 'Analyse de vos besoins', 'Étude technique', 'Conseils personnalisés', 'Devis détaillé sous 48h'].map((item) => (
                <li class="flex items-center gap-2 text-dark-300">
                  <CheckCircle class="w-4 h-4 text-accent-500" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="card">
            <h2 class="text-xl font-bold text-dark-900 mb-6">Formulaire de contact</h2>

            <form id="contact-form" class="space-y-6" data-formspree-id={SITE_CONFIG.formspreeId}>
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="lastName" class="block text-sm font-medium text-dark-700 mb-2">Nom *</label>
                  <input type="text" id="lastName" name="lastName" required class="input-field" placeholder="Dupont">
                </div>
                <div>
                  <label for="firstName" class="block text-sm font-medium text-dark-700 mb-2">Prénom *</label>
                  <input type="text" id="firstName" name="firstName" required class="input-field" placeholder="Jean">
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-medium text-dark-700 mb-2">Email *</label>
                  <input type="email" id="email" name="email" required class="input-field" placeholder="jean.dupont@email.com">
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-dark-700 mb-2">Téléphone *</label>
                  <input type="tel" id="phone" name="phone" required class="input-field" placeholder="06 12 34 56 78">
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-dark-700 mb-2">Type de logement *</label>
                  <div class="flex flex-wrap gap-3">
                    {housingTypes.map((type) => (
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="housingType" value={type.value} class="w-4 h-4 text-primary-500 focus:ring-primary-500" required>
                        <span class="text-dark-600">{type.label}</span>
                      </label>
                    ))}
                  </div>
                </div>
                <div>
                  <label for="postalCode" class="block text-sm font-medium text-dark-700 mb-2">Code postal *</label>
                  <input type="text" id="postalCode" name="postalCode" required pattern="[0-9]{5}" class="input-field" placeholder="75016">
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-dark-700 mb-2">Vos besoins (plusieurs choix possibles) *</label>
                <div class="flex flex-wrap gap-4">
                  {needs.map((need) => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="needs" value={need.value} class="w-4 h-4 text-primary-500 rounded focus:ring-primary-500">
                      <span class="text-dark-600">{need.label}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-dark-700 mb-2">Message (optionnel)</label>
                <textarea id="message" name="message" rows="4" class="input-field resize-none" placeholder="Décrivez votre projet ou posez vos questions..."></textarea>
              </div>

              <div>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" name="consent" required class="w-4 h-4 mt-0.5 text-primary-500 rounded focus:ring-primary-500">
                  <span class="text-sm text-dark-600">
                    J'accepte d'être recontacté par Neo Domotique pour mon projet. Mes données sont traitées conformément à la <a href="/mentions-legales#confidentialite" class="text-primary-500 hover:underline">politique de confidentialité</a>.
                  </span>
                </label>
              </div>

              <button type="submit" id="submit-btn" class="btn-primary w-full sm:w-auto">
                <Send class="w-5 h-5" id="submit-icon" />
                <svg id="submit-spinner" class="hidden animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span id="submit-text">Envoyer ma demande</span>
              </button>

              <div id="form-success" class="hidden p-4 bg-accent-500/10 border border-accent-500/20 rounded-xl">
                <div class="flex items-center gap-3 text-accent-600">
                  <CheckCircle class="w-5 h-5" />
                  <span class="font-medium">Merci ! Votre demande a été envoyée. Nous vous recontactons sous 24h.</span>
                </div>
              </div>

              <div id="form-error" class="hidden p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
                <p class="text-red-600">Une erreur est survenue. Veuillez réessayer ou nous contacter par téléphone.</p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');
  const errorMessage = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitIcon = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  const submitText = document.getElementById('submit-text');

  // --- Phase 3.1: Real-time validation ---
  const validators: Record<string, { regex: RegExp; message: string }> = {
    email: {
      regex: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,
      message: 'Adresse email invalide',
    },
    phone: {
      regex: /^(?:(?:\+33|0)\s*[1-9])(?:[\s.-]*\d{2}){4}$/,
      message: 'Numéro de téléphone français invalide',
    },
    postalCode: {
      regex: /^[0-9]{5}$/,
      message: 'Code postal à 5 chiffres requis',
    },
  };

  function validateField(input: HTMLInputElement) {
    const validator = validators[input.id];
    if (!validator || !input.value) return;

    const errorEl = input.parentElement?.querySelector('.field-error');

    if (validator.regex.test(input.value)) {
      input.classList.remove('border-red-500');
      input.classList.add('border-accent-500');
      if (errorEl) errorEl.remove();
    } else {
      input.classList.remove('border-accent-500');
      input.classList.add('border-red-500');
      if (!errorEl) {
        const msg = document.createElement('p');
        msg.className = 'field-error text-red-500 text-xs mt-1';
        msg.textContent = validator.message;
        input.parentElement?.appendChild(msg);
      }
    }
  }

  function clearValidation(input: HTMLInputElement) {
    input.classList.remove('border-red-500', 'border-accent-500');
    const errorEl = input.parentElement?.querySelector('.field-error');
    if (errorEl) errorEl.remove();
  }

  Object.keys(validators).forEach((fieldId) => {
    const input = document.getElementById(fieldId) as HTMLInputElement;
    if (!input) return;
    input.addEventListener('blur', () => validateField(input));
    input.addEventListener('input', () => {
      if (input.classList.contains('border-red-500') || input.classList.contains('border-accent-500')) {
        validateField(input);
      }
    });
  });

  // --- Form submission via Formspree ---
  // The FORMSPREE_ID is embedded as a data attribute to keep config in one place
  const FORMSPREE_URL = `https://formspree.io/f/${document.querySelector<HTMLFormElement>('#contact-form')?.dataset.formspreeId || 'TODO_FORM_ID'}`;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate all fields before submitting
    let hasErrors = false;
    Object.keys(validators).forEach((fieldId) => {
      const input = document.getElementById(fieldId) as HTMLInputElement;
      if (input?.value) {
        validateField(input);
        if (input.classList.contains('border-red-500')) hasErrors = true;
      }
    });
    if (hasErrors) return;

    // Set loading state
    submitBtn.disabled = true;
    submitIcon?.classList.add('hidden');
    submitSpinner?.classList.remove('hidden');
    if (submitText) submitText.textContent = 'Envoi en cours...';

    try {
      const formData = new FormData(form);

      const response = await fetch(FORMSPREE_URL, {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.reset();
        // Clear all validation styles
        Object.keys(validators).forEach((fieldId) => {
          const input = document.getElementById(fieldId) as HTMLInputElement;
          if (input) clearValidation(input);
        });
        successMessage?.classList.remove('hidden');
        errorMessage?.classList.add('hidden');
        successMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      errorMessage?.classList.remove('hidden');
      successMessage?.classList.add('hidden');
      errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } finally {
      // Reset button state
      submitBtn.disabled = false;
      submitIcon?.classList.remove('hidden');
      submitSpinner?.classList.add('hidden');
      if (submitText) submitText.textContent = 'Envoyer ma demande';
    }
  });
</script>
