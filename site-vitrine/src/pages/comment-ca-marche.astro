---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/sections/CTA.astro';
import { Calendar, FileText, Wrench, Smartphone, HeadphonesIcon, Check, ArrowRight } from '@lucide/astro';

const steps = [
  {
    number: '01',
    icon: 'Calendar',
    title: 'Audit gratuit à domicile',
    duration: '1 heure',
    description: 'Un expert se déplace chez vous pour analyser vos besoins et votre installation existante.',
    details: [
      'Analyse de vos besoins et habitudes',
      'Étude technique de votre logement',
      'Prise de mesures et photos',
      'Conseils personnalisés',
      'Réponses à toutes vos questions',
    ],
  },
  {
    number: '02',
    icon: 'FileText',
    title: 'Devis détaillé',
    duration: 'Sous 48h',
    description: 'Vous recevez une proposition claire et transparente, sans mauvaise surprise.',
    details: [
      'Choix du matériel adapté',
      'Scénarios d\'automatisation recommandés',
      'Prix détaillé et transparent',
      'Options et alternatives',
      'Sans engagement',
    ],
  },
  {
    number: '03',
    icon: 'Wrench',
    title: 'Installation soignée',
    duration: '1-3 jours selon projet',
    description: 'Nos techniciens certifiés installent et configurent votre système domotique.',
    details: [
      'Électriciens qualifiés',
      'Installation propre et soignée',
      'Configuration complète du système',
      'Création des automatisations',
      'Tests avant départ',
    ],
  },
  {
    number: '04',
    icon: 'Smartphone',
    title: 'Formation & prise en main',
    duration: '1 heure',
    description: 'Nous vous formons à l\'utilisation de votre nouveau système intelligent.',
    details: [
      'Démonstration complète',
      'Installation de l\'application',
      'Configuration de vos accès',
      'Documentation fournie',
      'Astuces et bonnes pratiques',
    ],
  },
  {
    number: '05',
    icon: 'Headphones',
    title: 'Maintenance & support',
    duration: 'Continu',
    description: 'Profitez d\'une tranquillité d\'esprit avec notre accompagnement sur le long terme.',
    details: [
      'Mises à jour automatiques',
      'Support technique réactif',
      'Monitoring à distance',
      'Évolutions possibles',
      'Garantie étendue',
    ],
  },
];
---

<BaseLayout
  title="Comment ça marche - Notre processus d'installation"
  description="Découvrez notre processus simple en 5 étapes : audit gratuit, devis sous 48h, installation professionnelle, formation et maintenance incluse."
  canonical="/comment-ca-marche"
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-dark-950 gradient-mesh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 bg-accent-500/10 text-accent-400 text-sm font-medium rounded-full mb-6">
          Processus simple
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Un accompagnement <span class="gradient-text">de A à Z</span>
        </h1>
        <p class="text-lg text-dark-300">
          De la première rencontre à la maintenance, nous vous guidons à chaque étape pour une transition en douceur vers la maison connectée.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <!-- Vertical Line -->
        <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary-500 via-accent-500 to-primary-500 hidden md:block"></div>

        <div class="space-y-12">
          {steps.map((step, index) => (
            <div class={`relative animate-on-scroll animation-delay-${index % 3}00`}>
              <div class="flex gap-8">
                <!-- Step Number -->
                <div class="flex-shrink-0 relative z-10 hidden md:block">
                  <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-accent-500 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-500/25">
                    <span class="text-xl font-bold text-white">{step.number}</span>
                  </div>
                </div>

                <!-- Content -->
                <div class="flex-grow card">
                  <div class="flex flex-col md:flex-row md:items-center gap-4 mb-4">
                    <div class="flex items-center gap-3">
                      <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center text-primary-500 md:hidden">
                        {step.icon === 'Calendar' && <Calendar class="w-6 h-6" />}
                        {step.icon === 'FileText' && <FileText class="w-6 h-6" />}
                        {step.icon === 'Wrench' && <Wrench class="w-6 h-6" />}
                        {step.icon === 'Smartphone' && <Smartphone class="w-6 h-6" />}
                        {step.icon === 'Headphones' && <HeadphonesIcon class="w-6 h-6" />}
                      </div>
                      <h2 class="text-xl font-bold text-dark-900">{step.title}</h2>
                    </div>
                    <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent-500/10 text-accent-600 text-sm font-medium rounded-full">
                      {step.duration}
                    </span>
                  </div>

                  <p class="text-dark-600 mb-6">{step.description}</p>

                  <ul class="grid sm:grid-cols-2 gap-3">
                    {step.details.map((detail) => (
                      <li class="flex items-start gap-2">
                        <Check class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" />
                        <span class="text-dark-600 text-sm">{detail}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-16 animate-on-scroll">
        <p class="text-lg text-dark-600 mb-6">
          Prêt à commencer ? La première étape est gratuite et sans engagement.
        </p>
        <a href="/contact" class="btn-primary text-lg px-8 py-4">
          Planifier mon audit gratuit
          <ArrowRight class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
